# ==========================================
# COMP-OS — SERVER ENVIRONMENT CONFIG
# ==========================================
# Config Version: 3.0.0
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values below
# 3. NEVER commit .env to version control
# ==========================================

# ==========================================
# 🛡️ SECURITY & AUTHENTICATION
# ==========================================
# REQUIRED: Server will refuse to start in production if this is not set.
# Generate a secure key using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=

# ==========================================
# 🌐 ENVIRONMENT & ROUTING
# ==========================================
# REQUIRED: Controls CORS policy, boot guards, and error detail.
# Valid values: 'development' | 'production'
# WARNING: Omitting this or setting it to 'development' in live environments 
# disables all security hardening and opens CORS to all origins!
NODE_ENV=development

# OPTIONAL: The port the server will bind to. 
# Default: 3001
PORT=3001

# ==========================================
# 🔒 NETWORK SECURITY (CORS)
# ==========================================
# REQUIRED in production: Comma-separated list of allowed frontend origins.
# Must match your actual domain exactly (No trailing slashes).
# Example: CORS_ORIGIN=https://veto.yourdomain.com
# Example (Multiple): CORS_ORIGIN=https://a.com,https://b.com
# WARNING: Omitting this blocks ALL socket connections in production.
CORS_ORIGIN=

# ==========================================
# 💾 PERSISTENCE (OPTIONAL)
# ==========================================
# Custom path to store the SQLite database. 
# If omitted, defaults to the 'server' directory.
# Example: DATABASE_PATH=/var/lib/data/match_history.db
# DATABASE_PATH=
