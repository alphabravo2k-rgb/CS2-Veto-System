# ==========================================
# COMP-OS — SERVER ENVIRONMENT CONFIG
# ==========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in ALL values below
# 3. Never commit .env to version control
# ==========================================

# ==========================================
# REQUIRED — Server will refuse to start in
# production if this is not set
# ==========================================
ADMIN_SECRET=change_this_to_your_secure_password_here

# ==========================================
# REQUIRED — Set to 'production' on live server
# Controls: CORS policy, boot guards, error detail
# WARNING: Omitting this disables all production
# security hardening and opens CORS to all origins
# ==========================================
NODE_ENV=production

# ==========================================
# REQUIRED in production — Comma-separated list
# of allowed frontend origins for CORS
# Must match your actual domain exactly
# Example: CORS_ORIGIN=https://veto.yourdomain.com
# Example (multiple): CORS_ORIGIN=https://a.com,https://b.com
# WARNING: Omitting this blocks ALL socket connections
# ==========================================
CORS_ORIGIN=https://your-domain-here.com
