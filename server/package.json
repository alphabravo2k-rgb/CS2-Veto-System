{
  "name": "cs2-mapveto-server",
  "version": "1.0.0",
  "description": "Backend server for CS2 Map Veto System",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "prestart": "node -e \"console.log('Migration handled by Supabase CLI')\"",
    "start": "node server.js",
    "start:prod": "node --max-old-space-size=512 server.js",
    "dev": "nodemon server.js",
    "migrate": "node migrate-db.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "cs2",
    "map-veto",
    "socket.io",
    "sqlite",
    "real-time"
  ],
  "author": "LOTGaming",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.100.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "nodemon": "^3.1.0"
  }
}
